{
    "id": "./",
    "name": "Rimlog — AI 독서·학습 일지",
    "short_name": "Rimlog",
    "description": "캡처한 메모를 AI가 연결하고 질문을 만들어 주는 두 번째 뇌",
    "icons": [
        {
            "src": "./images/app_icon_192x192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "maskable"
        },
        {
            "src": "./images/app_icon_512x512.png",
            "sizes": "512x512",
            "type": "image/png",
            "purpose": "maskable"
        }
    ],
    "start_url": "./serviceLoader.html",
    "theme_color": "#222222",
    "background_color": "#FFFFFF",
    "display_override": ["minimal-ui", "standalone"],
    "display": "window-controls-overlay",
